    given-names: Lenuta
    affiliation: "Faculty of Computer Science, Alexandru Ioan Cuza University of Iasi, Romania"
keywords:
  - LLM-assisted software engineering
  - microservices migration
  - monolith decomposition
  - reproducible case study
  - .NET
  - Claude Code
license: MIT
