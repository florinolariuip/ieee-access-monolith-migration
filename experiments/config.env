# Single source of truth for the experiment. Sourced by every runner script.
# Edit values here and only here.

# --- Paths -------------------------------------------------------------------
export SLICE1_REPO="/Users/florinolariu/Downloads/petrescue-net-slice1"
export SLICE2_REPO="/Users/florinolariu/Downloads/petrescue-net-slice2"
export SLICE1_REFACTORED_REPO="/Users/florinolariu/Downloads/petrescue-net-slice1-refactored"
export SKILLS_DIR="${HOME}/.claude/skills"
export EXPERIMENTS_DIR="/Users/florinolariu/Downloads/ieee-software-paper/experiments"
export RUNS_DIR="${EXPERIMENTS_DIR}/runs"

# --- Model & tool identity ---------------------------------------------------
# Bootstrap captures the precise dated model id once Claude Code reports it for
# the session; this is a defensible default if no override is provided.
export CLAUDE_MODEL="${CLAUDE_MODEL:-claude-sonnet-4-5-20250929}"
export CLAUDE_CLI_VERSION="$(claude --version 2>/dev/null | awk '{print $1}')"

# --- Run counts --------------------------------------------------------------
export REFACTOR_RUNS="${REFACTOR_RUNS:-10}"
export BASELINE_RUNS="${BASELINE_RUNS:-10}"
export FULL_CYCLE_RUNS="${FULL_CYCLE_RUNS:-5}"

# --- Run-time safety --------------------------------------------------------
# Per-run hard ceiling in seconds. /refactor on Slice 1 is normally < 8 min;
# anything beyond 20 min is a stuck run, kill it.
export RUN_TIMEOUT_SECONDS="${RUN_TIMEOUT_SECONDS:-1200}"

# --- Cost guard --------------------------------------------------------------
# If set to 1, every script will prompt before each run after the first.
# Useful while validating the harness; set to 0 once trust is established.
export INTERACTIVE_CONFIRM="${INTERACTIVE_CONFIRM:-1}"
