# Configuration overrides for the eShopOnWeb transfer case study.
# Source AFTER config.env to pin the codebase, rubric, scorer, and run dir.
# Example:
#   source experiments/config.env
#   source experiments/config_eshop.env
#   ./run_refactor_eshop.sh 3

export CODEBASE_TAG="eshop"
export CODEBASE_REPO="/Users/florinolariu/Downloads/eShopOnWeb"
export CODEBASE_RUBRIC="${EXPERIMENTS_DIR}/dimensions_eshop.json"
export CODEBASE_SCORER="${EXPERIMENTS_DIR}/scoring/score_eshop.py"
export REFACTOR_RUNS="${REFACTOR_RUNS:-3}"
export BASELINE_RUNS="${BASELINE_RUNS:-3}"
# Bigger codebase → allow longer per-run timeout. We OVERRIDE (not default)
# so this takes effect when config.env has already set the var to PetRescue's
# 1200s ceiling.
export RUN_TIMEOUT_SECONDS=1800
